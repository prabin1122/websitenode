NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://ecommerce:ecommerce@postgres:5432/ecommerce?schema=public
REDIS_URL=redis://redis:6379
JWT_ACCESS_SECRET=replace-with-secure-access-secret
JWT_REFRESH_SECRET=replace-with-secure-refresh-secret
EMAIL_FROM=notifications@shop.example.com
EMAIL_PROVIDER_API_KEY=changeme
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret
PAYPAL_CLIENT_ID=replace-with-paypal-client-id
PAYPAL_CLIENT_SECRET=replace-with-paypal-client-secret
PAYPAL_MODE=sandbox
